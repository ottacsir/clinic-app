<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Add Patient</h1>
    <a href="/patients" class="btn btn-edit">← Back</a>
</div>

<div class="form-card">
    <form action="/patients" method="POST">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Liya Tadesse" required>

        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="e.g. liya@example.com">

        <label for="phone">Phone</label>
        <input type="text" id="phone" name="phone" placeholder="e.g. 0911000000">

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Patient</button>
            <a href="/patients" class="btn btn-edit">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
