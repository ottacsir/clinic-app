<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Specialties</h1>
    <a href="/specialties/new" class="btn btn-primary">+ Add Specialty</a>
</div>

<div class="card">
    <div class="card-header">All Specialties</div>
    <table>
        <thead>
            <tr><th>ID</th><th>Name</th><th>Actions</th></tr>
        </thead>
        <tbody>
            <% specialties.forEach(s => { %>
                <tr>
                    <td><%= s.id %></td>
                    <td><span class="badge badge-specialty"><%= s.name %></span></td>
                    <td>
                        <div class="actions">
                            <a href="/specialties/<%= s.id %>/edit" class="btn btn-edit">Edit</a>
                            <form action="/specialties/<%= s.id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this specialty?')">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
