<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Add Specialty</h1>
    <a href="/specialties" class="btn btn-edit">← Back</a>
</div>

<div class="form-card">
    <form action="/specialties" method="POST">
        <label for="name">Specialty Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Cardiology" required>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Specialty</button>
            <a href="/specialties" class="btn btn-edit">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
