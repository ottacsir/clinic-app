<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Prescriptions</h1>
    <a href="/prescriptions/new" class="btn btn-primary">+ Add Prescription</a>
</div>

<div class="card">
    <div class="card-header">All Prescriptions</div>
    <table>
        <thead>
            <tr><th>Patient</th><th>Doctor</th><th>Date</th><th>Medication</th><th>Notes</th><th>Actions</th></tr>
        </thead>
        <tbody>
            <% prescriptions.forEach(p => { %>
                <tr>
                    <td><%= p.patient_name %></td>
                    <td><%= p.doctor_name %></td>
                    <td><%= p.appointment_date.toISOString().split('T')[0] %></td>
                    <td><%= p.medication || '—' %></td>
                    <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= p.notes || '—' %></td>
                    <td>
                        <div class="actions">
                            <a href="/prescriptions/<%= p.id %>/edit" class="btn btn-edit">Edit</a>
                            <form action="/prescriptions/<%= p.id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this prescription?')">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
