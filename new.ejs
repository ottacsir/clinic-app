<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Add Doctor</h1>
    <a href="/doctors" class="btn btn-edit">← Back</a>
</div>

<div class="form-card">
    <form action="/doctors" method="POST">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Dr. Abebe Kebede" required>

        <label for="specialty_id">Specialty</label>
        <select id="specialty_id" name="specialty_id">
            <option value="">-- Select specialty --</option>
            <% specialties.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.name %></option>
            <% }) %>
        </select>

        <label for="available_days">Available Days</label>
        <input type="text" id="available_days" name="available_days" placeholder="e.g. Mon, Wed, Fri">

        <label for="available_hours">Available Hours</label>
        <input type="text" id="available_hours" name="available_hours" placeholder="e.g. 9:00 AM - 4:00 PM">

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Doctor</button>
            <a href="/doctors" class="btn btn-edit">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
