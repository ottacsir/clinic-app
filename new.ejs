<%- include('../partials/header', { title: title }) %>

<div class="page-header">
    <h1>Add Prescription</h1>
    <a href="/prescriptions" class="btn btn-edit">← Back</a>
</div>

<div class="form-card">
    <form action="/prescriptions" method="POST">
        <label for="appointment_id">Appointment</label>
        <select id="appointment_id" name="appointment_id" required>
            <option value="">-- Select appointment --</option>
            <% appointments.forEach(a => { %>
                <option value="<%= a.id %>">
                    <%= a.patient_name %> with <%= a.doctor_name %> — <%= a.appointment_date.toISOString().split('T')[0] %>
                </option>
            <% }) %>
        </select>

        <label for="medication">Medication</label>
        <input type="text" id="medication" name="medication" placeholder="e.g. Amoxicillin 500mg">

        <label for="notes">Notes / Instructions</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Dosage instructions, diagnosis notes..."></textarea>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Prescription</button>
            <a href="/prescriptions" class="btn btn-edit">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
